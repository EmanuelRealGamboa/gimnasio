# Plantilla de variables de entorno.
# Copia este archivo a .env y ajusta los valores.
# (setup.sh genera el .env automáticamente; este archivo es solo de referencia.)

# Modo desarrollo (en producción/Railway debe ser False)
DEBUG=True

# Clave secreta de Django: ÚNICA y larga. Genera una con:
#   python -c "import secrets; print(secrets.token_urlsafe(64))"
DJANGO_SECRET_KEY=pon-aqui-una-clave-secreta-larga-y-unica

# Conexión a PostgreSQL
PGDATABASE=gimnasio
PGUSER=postgres
PGPASSWORD=postgres
PGHOST=localhost
PGPORT=5432
